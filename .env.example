# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin Credentials (stored server-side only)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your_secure_admin_password

# Session Secret (32+ char random string)
SESSION_SECRET=your_super_secret_session_key_minimum_32_chars

# App
NEXT_PUBLIC_APP_URL=http://localhost:4000

# Optional admin UI: In-app lead notifications row on Settings (default off; set true to show)
# NEXT_PUBLIC_FEATURE_IN_APP_LEAD_NOTIFICATIONS=true

# Web Push (VAPID) — generate: npx web-push generate-vapid-keys
# NEXT_PUBLIC_* is safe to expose; keep VAPID_PRIVATE_KEY server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com
